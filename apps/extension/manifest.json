{
  "manifest_version": 3,
  "name": "Careerly — Suivi de candidatures",
  "version": "1.0.0",
  "description": "Ajoutez une candidature Careerly en un clic depuis LinkedIn, Indeed, Welcome to the Jungle, JobTeaser et HelloWork.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://fr.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://fr.indeed.com/*",
    "https://www.welcometothejungle.com/*",
    "https://www.jobteaser.com/*",
    "https://www.hellowork.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ajouter une candidature",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
